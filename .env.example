# Core server
PORT=3000
NODE_ENV=development

# PostgreSQL (required for auth/workspaces)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=supcrud

# Auth
JWT_SECRET=replace_with_a_strong_secret
SESSION_SECRET=replace_with_a_strong_session_secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Cloudinary (attachments add-on)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI (AI add-on)
OPENAI_API_KEY=

# Email (OTP and ticket notifications)
EMAIL_FROM=
EMAIL_API_KEY=

# MongoDB (pending integration in this branch)
MONGO_URI=
